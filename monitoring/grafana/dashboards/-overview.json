{
  "dashboard": {
    "uid": "-overview",
    "title": " \u2014 Service Metrics",
    "description": "Auto-generated by ForgeFlow for fastapi application",
    "tags": [
      "",
      "fastapi",
      "forgeflow"
    ],
    "timezone": "browser",
    "schemaVersion": 38,
    "version": 1,
    "refresh": "30s",
    "time": {
      "from": "now-1h",
      "to": "now"
    },
    "templating": {
      "list": [
        {
          "name": "instance",
          "type": "query",
          "datasource": "Prometheus",
          "query": "label_values(up{job=\"\"}, instance)",
          "label": "Instance",
          "multi": true,
          "includeAll": true,
          "current": {
            "selected": false,
            "text": "All",
            "value": "$__all"
          }
        }
      ]
    },
    "panels": [
      {
        "id": 1,
        "type": "stat",
        "title": "Service Status",
        "gridPos": {
          "x": 0,
          "y": 0,
          "w": 4,
          "h": 3
        },
        "datasource": "Prometheus",
        "fieldConfig": {
          "defaults": {
            "unit": "short",
            "thresholds": {
              "mode": "absolute",
              "steps": [
                {
                  "color": "green",
                  "value": null
                }
              ]
            },
            "mappings": [
              {
                "type": "value",
                "options": {
                  "0": {
                    "text": "DOWN",
                    "color": "red"
                  },
                  "1": {
                    "text": "UP",
                    "color": "green"
                  }
                }
              }
            ]
          }
        },
        "targets": [
          {
            "expr": "up{job=\"\"}",
            "instant": true,
            "legendFormat": ""
          }
        ],
        "options": {
          "reduceOptions": {
            "calcs": [
              "lastNotNull"
            ]
          },
          "orientation": "auto"
        }
      },
      {
        "id": 2,
        "type": "stat",
        "title": "Request Rate (RPS)",
        "gridPos": {
          "x": 4,
          "y": 0,
          "w": 5,
          "h": 3
        },
        "datasource": "Prometheus",
        "fieldConfig": {
          "defaults": {
            "unit": "reqps",
            "thresholds": {
              "mode": "absolute",
              "steps": [
                {
                  "color": "green",
                  "value": null
                }
              ]
            },
            "mappings": []
          }
        },
        "targets": [
          {
            "expr": "sum(rate(http_requests_total{job=\"\"}[2m]))",
            "instant": true,
            "legendFormat": ""
          }
        ],
        "options": {
          "reduceOptions": {
            "calcs": [
              "lastNotNull"
            ]
          },
          "orientation": "auto"
        }
      },
      {
        "id": 3,
        "type": "stat",
        "title": "Error Rate",
        "gridPos": {
          "x": 9,
          "y": 0,
          "w": 5,
          "h": 3
        },
        "datasource": "Prometheus",
        "fieldConfig": {
          "defaults": {
            "unit": "percentunit",
            "thresholds": {
              "mode": "absolute",
              "steps": [
                {
                  "color": "green",
                  "value": null
                },
                {
                  "color": "yellow",
                  "value": 0.01
                },
                {
                  "color": "red",
                  "value": 0.05
                }
              ]
            },
            "mappings": []
          }
        },
        "targets": [
          {
            "expr": "sum(rate(http_requests_total{job=\"\",status=~\"5..\"}[5m])) / sum(rate(http_requests_total{job=\"\"}[5m]))",
            "instant": true,
            "legendFormat": ""
          }
        ],
        "options": {
          "reduceOptions": {
            "calcs": [
              "lastNotNull"
            ]
          },
          "orientation": "auto"
        }
      },
      {
        "id": 4,
        "type": "stat",
        "title": "p99 Latency",
        "gridPos": {
          "x": 14,
          "y": 0,
          "w": 5,
          "h": 3
        },
        "datasource": "Prometheus",
        "fieldConfig": {
          "defaults": {
            "unit": "s",
            "thresholds": {
              "mode": "absolute",
              "steps": [
                {
                  "color": "green",
                  "value": null
                },
                {
                  "color": "yellow",
                  "value": 0.5
                },
                {
                  "color": "red",
                  "value": 2.0
                }
              ]
            },
            "mappings": []
          }
        },
        "targets": [
          {
            "expr": "histogram_quantile(0.99, sum(rate(http_request_duration_seconds_bucket{job=\"\"}[5m])) by (le))",
            "instant": true,
            "legendFormat": ""
          }
        ],
        "options": {
          "reduceOptions": {
            "calcs": [
              "lastNotNull"
            ]
          },
          "orientation": "auto"
        }
      },
      {
        "id": 5,
        "type": "timeseries",
        "title": "Request Rate by Status",
        "gridPos": {
          "x": 0,
          "y": 3,
          "w": 12,
          "h": 8
        },
        "datasource": "Prometheus",
        "fieldConfig": {
          "defaults": {
            "unit": "reqps",
            "custom": {
              "lineWidth": 2,
              "fillOpacity": 10
            }
          }
        },
        "targets": [
          {
            "expr": "sum by (status) (rate(http_requests_total{job=\"\"}[2m]))",
            "legendFormat": "{{status}}",
            "refId": "A"
          }
        ],
        "options": {
          "tooltip": {
            "mode": "multi"
          },
          "legend": {
            "displayMode": "list"
          }
        }
      },
      {
        "id": 6,
        "type": "timeseries",
        "title": "Response Latency Percentiles",
        "gridPos": {
          "x": 12,
          "y": 3,
          "w": 12,
          "h": 8
        },
        "datasource": "Prometheus",
        "fieldConfig": {
          "defaults": {
            "unit": "s",
            "custom": {
              "lineWidth": 2,
              "fillOpacity": 10
            }
          }
        },
        "targets": [
          {
            "expr": "histogram_quantile(0.50, sum(rate(http_request_duration_seconds_bucket{job=\"\"}[5m])) by (le))",
            "legendFormat": "p50",
            "refId": "A"
          },
          {
            "expr": "histogram_quantile(0.95, sum(rate(http_request_duration_seconds_bucket{job=\"\"}[5m])) by (le))",
            "legendFormat": "p95",
            "refId": "B"
          },
          {
            "expr": "histogram_quantile(0.99, sum(rate(http_request_duration_seconds_bucket{job=\"\"}[5m])) by (le))",
            "legendFormat": "p99",
            "refId": "C"
          }
        ],
        "options": {
          "tooltip": {
            "mode": "multi"
          },
          "legend": {
            "displayMode": "list"
          }
        }
      },
      {
        "id": 7,
        "type": "timeseries",
        "title": "Memory Usage",
        "gridPos": {
          "x": 0,
          "y": 11,
          "w": 8,
          "h": 8
        },
        "datasource": "Prometheus",
        "fieldConfig": {
          "defaults": {
            "unit": "bytes",
            "custom": {
              "lineWidth": 2,
              "fillOpacity": 10
            }
          }
        },
        "targets": [
          {
            "expr": "process_resident_memory_bytes{job=\"\"}",
            "legendFormat": "RSS Memory",
            "refId": "A"
          }
        ],
        "options": {
          "tooltip": {
            "mode": "multi"
          },
          "legend": {
            "displayMode": "list"
          }
        }
      },
      {
        "id": 8,
        "type": "timeseries",
        "title": "CPU Usage",
        "gridPos": {
          "x": 8,
          "y": 11,
          "w": 8,
          "h": 8
        },
        "datasource": "Prometheus",
        "fieldConfig": {
          "defaults": {
            "unit": "percent",
            "custom": {
              "lineWidth": 2,
              "fillOpacity": 10
            }
          }
        },
        "targets": [
          {
            "expr": "rate(process_cpu_seconds_total{job=\"\"}[2m]) * 100",
            "legendFormat": "CPU %",
            "refId": "A"
          }
        ],
        "options": {
          "tooltip": {
            "mode": "multi"
          },
          "legend": {
            "displayMode": "list"
          }
        }
      },
      {
        "id": 9,
        "type": "timeseries",
        "title": "Active Goroutines / Threads",
        "gridPos": {
          "x": 16,
          "y": 11,
          "w": 8,
          "h": 8
        },
        "datasource": "Prometheus",
        "fieldConfig": {
          "defaults": {
            "unit": "short",
            "custom": {
              "lineWidth": 2,
              "fillOpacity": 10
            }
          }
        },
        "targets": [
          {
            "expr": "go_goroutines{job=\"\"}",
            "legendFormat": "Goroutines (Go)",
            "refId": "A"
          },
          {
            "expr": "process_open_fds{job=\"\"}",
            "legendFormat": "Open FDs",
            "refId": "B"
          }
        ],
        "options": {
          "tooltip": {
            "mode": "multi"
          },
          "legend": {
            "displayMode": "list"
          }
        }
      },
      {
        "id": 10,
        "type": "timeseries",
        "title": "GC Pause Duration",
        "gridPos": {
          "x": 0,
          "y": 19,
          "w": 12,
          "h": 7
        },
        "datasource": "Prometheus",
        "fieldConfig": {
          "defaults": {
            "unit": "s",
            "custom": {
              "lineWidth": 2,
              "fillOpacity": 10
            }
          }
        },
        "targets": [
          {
            "expr": "rate(go_gc_duration_seconds_sum{job=\"\"}[5m]) / rate(go_gc_duration_seconds_count{job=\"\"}[5m])",
            "legendFormat": "Mean GC Pause",
            "refId": "A"
          }
        ],
        "options": {
          "tooltip": {
            "mode": "multi"
          },
          "legend": {
            "displayMode": "list"
          }
        }
      },
      {
        "id": 11,
        "type": "timeseries",
        "title": "Node CPU",
        "gridPos": {
          "x": 12,
          "y": 19,
          "w": 12,
          "h": 7
        },
        "datasource": "Prometheus",
        "fieldConfig": {
          "defaults": {
            "unit": "percent",
            "custom": {
              "lineWidth": 2,
              "fillOpacity": 10
            }
          }
        },
        "targets": [
          {
            "expr": "100 - (avg by (instance) (irate(node_cpu_seconds_total{mode=\"idle\"}[5m])) * 100)",
            "legendFormat": "{{instance}} CPU %",
            "refId": "A"
          }
        ],
        "options": {
          "tooltip": {
            "mode": "multi"
          },
          "legend": {
            "displayMode": "list"
          }
        }
      }
    ]
  },
  "overwrite": true,
  "folderId": 0
}