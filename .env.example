# ForgeFlow Environment Configuration
# Copy this file to .env and fill in your values
# Usage: cp .env.example .env

# ============================================
# PUBLIC MODE - Required for --mode public
# ============================================

# Your ForgeFlow API key (required for PUBLIC mode)
# Get your key from: https://forgeflow.io/dashboard/api-keys
FORGEFLOW_API_KEY=your_api_key_here

# Custom API endpoint (optional, defaults to ForgeFlow cloud)
# FORGEFLOW_API_URL=https://api.forgeflow.io

# ============================================
# HYBRID MODE - Optional integrations
# ============================================

# GitHub Integration (for bridge operations)
# GITHUB_TOKEN=ghp_xxxxx

# Security Scanning Integrations
# SNYK_API_KEY=your_snyk_key
# SONARQUBE_URL=https://sonarqube.example.com
# SONARQUBE_TOKEN=your_sonar_token

# Cloud Provider Integrations
# AWS_REGION=us-east-1
# AWS_PROFILE=default
# GCP_PROJECT=your-project-id
# GOOGLE_APPLICATION_CREDENTIALS=/path/to/credentials.json
# AZURE_SUBSCRIPTION_ID=your-subscription-id

# Observability Integrations
# PROMETHEUS_URL=http://prometheus:9090
# GRAFANA_URL=http://grafana:3000
# GRAFANA_API_KEY=your_grafana_key
# DD_API_KEY=your_datadog_key

# ============================================
# OAuth Configuration (Enterprise)
# ============================================

# OAuth credentials for enterprise SSO
# FORGEFLOW_CLIENT_ID=your_client_id
# FORGEFLOW_CLIENT_SECRET=your_client_secret

# ============================================
# Development Settings
# ============================================

# Enable debug output
# FORGEFLOW_DEBUG=true

# Custom configuration file path
# FORGEFLOW_CONFIG=/path/to/custom-config.yaml
